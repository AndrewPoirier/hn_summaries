{
    "dry_run": false,

    "load_new_articles": true,
    "generate_summaries": true,
    "max_articles": 50,
    "max_items_to_keep": 1000,
    "max_comments": 3,
    "data_file": "data/articles.pkl",
    "logging_folder": "logs/",
    "articles_url": "https://news.ycombinator.com/front?day={date}&p={page}",
    "comment_url": "https://news.ycombinator.com/item?id=",
    "hn_request_delay_seconds": 0.75,
    "request_user_agent": "hn_summaries/1.0",
    "request_timeout_seconds": 45,
    "request_cache_ttl_seconds": 3600,
    "cooldown_trigger_429s": 2,
    "cooldown_seconds": 120
}